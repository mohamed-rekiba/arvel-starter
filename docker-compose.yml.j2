# Arvel Starter — local development stack
#
# Usage:
#   docker compose up        — start all services
#   docker compose up -d     — start in background
#   docker compose down -v   — stop and remove volumes
#
# Default credentials are FOR DEVELOPMENT ONLY — never use in production.

services:
{% if use_postgres %}
  postgres:
    image: postgres:18-trixie
    environment:
      POSTGRES_DB: {{ db_database }}
      POSTGRES_USER: {{ db_username }}
      POSTGRES_PASSWORD: {{ db_password }}
      PGPASSWORD: {{ db_password }}
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ db_username }} -d {{ db_database }}"]
      interval: 5s
      timeout: 3s
      retries: 5
    restart: unless-stopped

{% endif %}
{% if use_redis %}
  valkey:
    image: valkey/valkey:9-alpine
    ports:
      - "6379:6379"
    volumes:
      - valkeydata:/data
    healthcheck:
      test: ["CMD", "valkey-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
    restart: unless-stopped

{% endif %}
{% if use_smtp %}
  mailpit:
    image: axllent/mailpit:v1.29
    ports:
      - "1025:1025"   # SMTP
      - "8025:8025"   # Web UI
    restart: unless-stopped

{% endif %}
{% if use_meilisearch %}
  meilisearch:
    image: getmeili/meilisearch:v1
    environment:
      MEILI_MASTER_KEY: devMasterKey   # DEV ONLY
      MEILI_ENV: development
    ports:
      - "7700:7700"
    volumes:
      - meilidata:/meili_data
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://127.0.0.1:7700/health"]
      interval: 5s
      timeout: 3s
      retries: 5
    restart: unless-stopped

{% endif %}
{% if use_s3 %}
  minio:
    image: minio/minio:RELEASE.2025-09-07T16-13-09Z
    command: server /data --console-address ":9001"
    environment:
      MINIO_ROOT_USER: minioadmin      # DEV ONLY
      MINIO_ROOT_PASSWORD: minioadmin  # DEV ONLY
    ports:
      - "9000:9000"   # S3 API
      - "9001:9001"   # Console
    volumes:
      - miniodata:/data
    healthcheck:
      test: ["CMD", "mc", "ready", "local"]
      interval: 5s
      timeout: 3s
      retries: 5
    restart: unless-stopped

  minio-init:
    image: minio/mc:latest
    depends_on:
      minio:
        condition: service_healthy
    entrypoint: >
      /bin/sh -c "
      mc alias set local http://minio:9000 minioadmin minioadmin &&
      mc mb --ignore-existing local/arvel-dev &&
      mc anonymous set download local/arvel-dev &&
      echo 'Bucket arvel-dev ready'
      "

{% endif %}
{% if use_postgres or use_redis or use_s3 or use_meilisearch %}
volumes:
{% if use_postgres %}
  pgdata:
{% endif %}
{% if use_redis %}
  valkeydata:
{% endif %}
{% if use_s3 %}
  miniodata:
{% endif %}
{% if use_meilisearch %}
  meilidata:
{% endif %}
{% endif %}
