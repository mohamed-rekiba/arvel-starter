# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME={{ app_name_title }}
APP_ENV=local
APP_DEBUG=true
APP_KEY={{ secret_key }}
APP_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DB_DRIVER={{ database_driver }}
DB_DATABASE={{ db_database }}
{% if database_driver != "sqlite" %}
DB_HOST={{ db_host }}
DB_PORT={{ db_port }}
DB_USERNAME={{ db_username }}
DB_PASSWORD={{ db_password }}
{% else %}
DB_URL=
DB_HOST=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=
{% endif %}

DB_ECHO=true
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true
DB_EXPIRE_ON_COMMIT=false

# ---------------------------------------------------------------------------
# Logging / Observability
# ---------------------------------------------------------------------------
OBSERVABILITY_LOG_LEVEL=debug
OBSERVABILITY_LOG_FORMAT=auto
OBSERVABILITY_LOG_COLOR_MODE=auto
OBSERVABILITY_LOG_COLOR_DISABLE_IN_CI=true

# ---------------------------------------------------------------------------
# Session / Cache / Queue
# ---------------------------------------------------------------------------
SESSION_DRIVER=memory
SESSION_LIFETIME=120

CACHE_DRIVER={{ cache_driver }}
CACHE_PREFIX=
CACHE_DEFAULT_TTL=3600
CACHE_REDIS_URL=redis://localhost:6379/0

QUEUE_DRIVER={{ queue_driver }}
QUEUE_DEFAULT=default
QUEUE_REDIS_URL=redis://localhost:6379
QUEUE_TASKIQ_BROKER=redis
QUEUE_TASKIQ_URL=redis://localhost:6379/1

# ---------------------------------------------------------------------------
# Mail
# ---------------------------------------------------------------------------
MAIL_DRIVER={{ mail_driver }}
MAIL_FROM_ADDRESS=noreply@localhost
MAIL_FROM_NAME={{ app_name_title }}
MAIL_SMTP_HOST=localhost
MAIL_SMTP_PORT=1025
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_SMTP_USE_TLS=false
MAIL_TEMPLATE_DIR=templates/mail

# ---------------------------------------------------------------------------
# Storage (S3 / Local)
# ---------------------------------------------------------------------------
STORAGE_DRIVER={{ storage_driver }}
STORAGE_S3_BUCKET=arvel-dev
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ENDPOINT_URL=http://localhost:9000
STORAGE_S3_ACCESS_KEY=minioadmin
STORAGE_S3_SECRET_KEY=minioadmin

# ---------------------------------------------------------------------------
# Lock
# ---------------------------------------------------------------------------
LOCK_DRIVER=memory
LOCK_DEFAULT_TTL=30
LOCK_REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Media  (disk is inherited from STORAGE_DRIVER above)
#   conversion_quality: JPEG/WEBP quality 1-100 (default 85)
#   conversion_format:  "source" keeps original format, or "webp"/"jpeg"/"png"
# ---------------------------------------------------------------------------
MEDIA_MAX_DIMENSION=10000
MEDIA_PATH_PREFIX=media
MEDIA_CONVERSION_QUALITY=85
MEDIA_CONVERSION_FORMAT=source

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------
NOTIFICATION_DEFAULT_CHANNELS=["mail"]
NOTIFICATION_SLACK_WEBHOOK_URL=
NOTIFICATION_DATABASE_TABLE=notifications

# ---------------------------------------------------------------------------
# Scheduler
# ---------------------------------------------------------------------------
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
SCHEDULER_LOCK_BACKEND=memory

# ---------------------------------------------------------------------------
# Search
# ---------------------------------------------------------------------------
SEARCH_DRIVER={{ search_driver }}
SEARCH_PREFIX=
SEARCH_QUEUE_SYNC=false
SEARCH_MEILISEARCH_URL=http://localhost:7700
SEARCH_MEILISEARCH_KEY=

# ---------------------------------------------------------------------------
# Broadcasting
# ---------------------------------------------------------------------------
BROADCAST_DRIVER={{ broadcast_driver }}
BROADCAST_REDIS_URL=redis://localhost:6379/2
BROADCAST_AUTH_ENDPOINT=/broadcasting/auth
