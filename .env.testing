# ---------------------------------------------------------------------------
# Testing overrides — loaded automatically when testing=True
# ---------------------------------------------------------------------------
# Forces SQLite and local/in-memory drivers so tests run without external
# services (PostgreSQL, Redis, MinIO, Meilisearch).
# ---------------------------------------------------------------------------

DB_DRIVER=sqlite
DB_DATABASE=database/database.sqlite
DB_URL=

STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=.tests/storage/app

CACHE_DRIVER=memory
LOCK_DRIVER=memory
QUEUE_DRIVER=sync
SEARCH_DRIVER=collection
BROADCAST_DRIVER=memory
MAIL_DRIVER=log
