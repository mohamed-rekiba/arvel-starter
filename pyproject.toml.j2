[project]
name = "{{ app_name }}"
version = "0.1.0"
description = ""
readme = "README.md"
requires-python = ">={{ python_version }}"
dependencies = ["arvel{{ arvel_extras }}>={{ arvel_version }}"]

[project.optional-dependencies]
dev = [
    "faker>=40.13.0",
    "pytest>=9.0.3",
    "pytest-cov>=7.0.0",
    "pytest-timeout>=2.4.0",
    "dirty-equals>=0.11",
    "anyio[trio]>=4.13.0",
    "filelock>=3.18.0",
    "ruff>=0.15.9",
    "ty>=0.0.29",
]

[tool.uv.sources]
arvel = { git = "https://github.com/mohamed-rekiba/arvel", tag = "v{{ arvel_version }}" }

[tool.uv]
package = false

[tool.hatch.build.targets.wheel]
packages = ["."]

[tool.pytest.ini_options]
testpaths = ["tests"]
pythonpath = ["."]
addopts = ["--strict-config", "--strict-markers", "-x", "--tb=short"]
xfail_strict = true
filterwarnings = ["error", "ignore::DeprecationWarning:aiosqlite.*"]
timeout = 30
markers = [
    "db: marks tests that require database (deselect with '-m \"not db\"')",
    "integration: marks tests requiring live services (Docker)",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.ruff]
target-version = "py314"
line-length = 100
extend-exclude = ["database/migrations/versions"]

[tool.ruff.lint]
select = [
    "E",     # pycodestyle errors
    "F",     # pyflakes (unused imports, undefined names)
    "W",     # pycodestyle warnings
    "I",     # isort
    "N",     # pep8-naming
    "UP",    # pyupgrade
    "B",     # flake8-bugbear
    "A",     # flake8-builtins
    "SIM",   # flake8-simplify
    "TCH",   # flake8-type-checking
    "RUF",   # ruff-specific rules
    "ASYNC", # flake8-async
    "S",     # flake8-bandit security checks
    "PTH",   # flake8-use-pathlib
    "C90",   # mccabe complexity
    "ANN",   # flake8-annotations
]
ignore = [
    "ANN401", # Any in signatures is acceptable
    "B008",   # Inject() / File() / Query() / Path() in defaults is the Arvel DI pattern
]

[tool.ruff.lint.per-file-ignores]
"tests/**/*.py" = [
    "S101",    # assert is fine in tests
    "S105",    # hardcoded passwords/tokens are fine in fixtures
    "S106",    # hardcoded password args are fine in test fixtures
    "S107",    # hardcoded password defaults are fine in test factories
    "PLR2004", # magic values are fine in assertions
    "ANN",     # test functions don't need type annotations
    "TC001",   # type-checking imports not needed in tests
]
"database/factories/**/*.py" = [
    "S107",  # hardcoded password defaults are fine in factories
    "TC001", # type-checking imports not needed in factories
]

[tool.ruff.lint.flake8-annotations]
allow-star-arg-any = true
suppress-none-returning = true

[tool.ruff.lint.flake8-type-checking]
strict = true

[tool.ruff.format]
quote-style = "double"

[tool.ruff.lint.isort]
known-first-party = ["arvel"]
